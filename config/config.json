{
    "paths": {
        "log_dir": "logs/",
        "model_save_dir": "saved_models/"
    },
    "model": {
        "architecture": "resnet18",
        "pretrained": true,
        "num_classes": 1,
        "freeze_backbone": true
    },
    "classes": {
        "mapping": {
            "0": "No_Obstacle",
            "1": "Obstacle"
        }
    },
    "training_parameters": {
        "batch_size": 128,
        "learning_rate": 0.001,
        "epochs": 10 ,
        "image_size": 224,
        "seed": 1,
        "accumulation_steps": 4,
        "early_stopping_patience" : 5
    },
    "hardware": {
        "num_workers": 4
    }
}